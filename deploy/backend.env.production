# IDSEA Backend — Production Environment
# Copy to /var/www/idsea/backend/.env

MONGO_URL=mongodb://localhost:27017
DB_NAME=idsea_db
CORS_ORIGINS=https://idsea.in,https://www.idsea.in
JWT_SECRET_KEY=CHANGE_ME_RUN_python3_-c_"import secrets; print(secrets.token_hex(32))"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@idsea.in
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
